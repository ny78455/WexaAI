# Application
APP_NAME=Wexa Analytics
DEBUG=false
SECRET_KEY=change-me-to-a-256-bit-random-secret

# Database
DATABASE_URL=postgresql+asyncpg://wexa:wexapassword@localhost:5432/wexa_db
DATABASE_URL_SYNC=postgresql://wexa:wexapassword@localhost:5432/wexa_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# Email (optional — leave empty to use console logging)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@wexa.ai
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# Frontend URL
FRONTEND_URL=http://localhost:3000
